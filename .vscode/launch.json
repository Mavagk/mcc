	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug executable 'mcc'",
			"type": "lldb",
			"request": "launch",
			"cargo": {
				"args": [
					"run",
					"--bin=mcc"
				]
			},
			"args": ["--version", "--help", "--print-tokens", "--print-ast", "--print-ast-after-const-compile", "--print-ast-post-parse", "--source-dir", "mmcsrc", "--entrypoint-module", "c.tnk", "--print-c", "-O3", "--stop-after-const-compile"]
		},
		{
			"name": "Debug unit tests in executable 'mcc'",
			"type": "lldb",
			"request": "launch",
			"cargo": {
				"args": [
					"test",
					"--bin=mcc"
				]
			}
		}
	]
}