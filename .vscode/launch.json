	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug executable 'mcc'",
			"type": "lldb",
			"request": "launch",
			"cargo": {
				"args": [
					"run",
					"--bin=mcc"
				]
			},
			"args": ["--version", "--help", "--print-tokens", "--print-ast", "--source-dir", "mmcsrc", "--entrypoint-module", "hello_world.bf", "--execute-interpreted"]
		},
		{
			"name": "Debug unit tests in executable 'mcc'",
			"type": "lldb",
			"request": "launch",
			"cargo": {
				"args": [
					"test",
					"--bin=mcc"
				]
			}
		}
	]
}